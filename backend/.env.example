# PostgreSQL
# Local: conexión directa.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tu_chamba?schema=public"
# Vercel (serverless): usar SIEMPRE una URL con pooling (Neon pooler, Supabase
# pgbouncer o Prisma Accelerate). Una conexión directa agota el pool de Postgres.
# Ej Neon: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require&pgbouncer=true

# JWT
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001

# Orígenes permitidos para CORS (web, admin). Separados por coma.
CORS_ORIGINS="http://localhost:3000,http://localhost:3002"
