# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tu_chamba?schema=public"

# JWT
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001

# Orígenes permitidos para CORS (web, admin). Separados por coma.
CORS_ORIGINS="http://localhost:3000,http://localhost:3002"

# Google Sign-In (opcional). OAuth Client ID de Google Cloud Console.
# Si no se define, POST /auth/google responde 503 y el botón no se muestra en web.
GOOGLE_CLIENT_ID=""
